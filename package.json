{
  "name": "mdpublish",
  "version": "0.1.0",
  "description": "CLI and library for validating markdown frontmatter and generating a typed blog manifest",
  "keywords": [
    "markdown",
    "blog",
    "frontmatter",
    "cli",
    "static-site",
    "content",
    "generator",
    "typescript",
    "validation"
  ],
  "license": "MIT",
  "author": "Muhammad Ismail <ismail@atlasflowai.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/ismail-rt/mdpublish.git"
  },
  "homepage": "https://github.com/ismail-rt/mdpublish#readme",
  "bugs": {
    "url": "https://github.com/ismail-rt/mdpublish/issues"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "mdpublish": "bin/mdpublish.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "gray-matter": "^4.0.3",
    "picocolors": "^1.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
